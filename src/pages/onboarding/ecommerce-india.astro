---
import BaseLayout from '../../layouts/BaseLayout.astro';
import OnboardingGuide from '../../components/onboarding/OnboardingGuide.astro';
import { indiaGuide } from '../../data/onboarding';
import { SITE_URL } from '../../config';
---

<BaseLayout
  recaptcha={false}
  title="Ecommerce Onboarding for India - What to Expect | Uxory"
  description="A step-by-step guide to building your ecommerce store with Uxory in India: platform choice, payments (Razorpay/UPI), SMS OTP & DLT, legal pages, and launch."
  canonical={`${SITE_URL}/onboarding/ecommerce-india`}
  currentPage="onboarding-india"
  currentParent="docs"
>
  <OnboardingGuide
    guide={indiaGuide}
    otherHref="/onboarding/ecommerce-usa"
    otherLabel="USA"
  />
</BaseLayout>
