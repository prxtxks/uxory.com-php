---
import BlogArticle from '../../layouts/BlogArticle.astro';
import { fetchBlogBySlug, renderMarkdown } from '../../lib/blog';
import { SITE_URL } from '../../config';

export const prerender = false;

const { slug } = Astro.params;
const post = slug ? await fetchBlogBySlug(slug) : null;

// If not a DB post (the 3 original static pages have their own files, and
// unknown slugs), 404.
if (!post || !post.content_md) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const html = renderMarkdown(post.content_md);
const hero = post.hero_image || post.image;
const heroMobile = post.hero_image ? hero.replace('-wide.webp', '-tall.webp') : undefined;
const canonical = `${SITE_URL}${post.link || `/blogs/${post.slug}`}`;
const published = post.created_at || new Date().toISOString();
const ogImage = hero?.startsWith('http') ? hero : `${SITE_URL}${hero}`;

const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  image: ogImage,
  datePublished: published,
  author: { '@type': 'Organization', name: 'Uxory', url: SITE_URL },
  publisher: {
    '@type': 'Organization',
    name: 'Uxory',
    logo: { '@type': 'ImageObject', url: `${SITE_URL}/images/logo.png` },
  },
  mainEntityOfPage: canonical,
});
---

<BlogArticle
  title={post.title}
  description={post.excerpt}
  excerpt={post.excerpt}
  category={post.category || undefined}
  date={published}
  readTime={post.read_time}
  heroImage={hero}
  heroImageMobile={heroMobile}
  canonical={canonical}
  ogImage={ogImage}
  structuredData={structuredData}
  sources={post.source_urls || undefined}
  bodyHtml={html}
/>
