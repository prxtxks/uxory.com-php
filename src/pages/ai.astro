---
import BaseLayout from '../layouts/BaseLayout.astro';
import UxoryAI from '../components/ai/UxoryAI.tsx';
import { SITE_URL } from '../config';

const structuredData = `
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Uxory AI",
  "url": "${SITE_URL}/ai",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any (web browser)",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Chat with Uxory AI - a free, no-login assistant that helps you scope websites, apps, AI agents and automation for your business."
}
`;
---

<BaseLayout
  title="Uxory AI - Free AI Assistant for Your Business"
  description="Chat with Uxory AI, a free assistant that helps you plan websites, apps, AI agents and automation. No account, no login - just ask."
  canonical={`${SITE_URL}/ai`}
  currentPage="ai"
  currentParent="tools"
  structuredData={structuredData}
  noFooter
  noMainWrapper
  recaptcha={false}
>
  <main id="main-content" class="relative z-10">
    <UxoryAI client:load />
  </main>
</BaseLayout>
