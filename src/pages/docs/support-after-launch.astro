---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLayout from '../../components/docs/DocLayout.astro';
import DocsShell from '../../components/docs/DocsShell.astro';
import { supportAfterLaunch } from '../../data/docs';
import { SITE_URL } from '../../config';
---

<BaseLayout
  recaptcha={false}
  title="Requesting Changes and Support After Launch | Uxory Docs"
  description="How support works after your site goes live: what free support covers, the difference between maintenance and new work, and how to request a change."
  canonical={`${SITE_URL}/docs/support-after-launch`}
  currentPage="docs-support"
  currentParent="docs"
>
  <DocsShell current="/docs/support-after-launch">
    <DocLayout doc={supportAfterLaunch} />
  </DocsShell>
</BaseLayout>
