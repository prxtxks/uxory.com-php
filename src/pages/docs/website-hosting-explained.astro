---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLayout from '../../components/docs/DocLayout.astro';
import DocsShell from '../../components/docs/DocsShell.astro';
import { hostingExplained } from '../../data/docs';
import { SITE_URL } from '../../config';
---

<BaseLayout
  recaptcha={false}
  title="Website Hosting Types Explained | Uxory Docs"
  description="Shared, VPS, managed, cloud, dedicated, and hosted store platforms explained in plain language, with a comparison table and guidance on how to choose."
  canonical={`${SITE_URL}/docs/website-hosting-explained`}
  currentPage="docs-hosting"
  currentParent="docs"
>
  <DocsShell current="/docs/website-hosting-explained">
    <DocLayout doc={hostingExplained} />
  </DocsShell>
</BaseLayout>
