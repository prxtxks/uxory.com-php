---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import DocsShell from '../../../components/docs/DocsShell.astro';
import OnboardingGuide from '../../../components/onboarding/OnboardingGuide.astro';
import { usaGuide } from '../../../data/onboarding';
import { SITE_URL } from '../../../config';
---

<BaseLayout
  recaptcha={false}
  title="Ecommerce Onboarding for USA - What to Expect | Uxory Docs"
  description="A step-by-step guide to building your ecommerce store with Uxory in the USA: platform choice, payments (Stripe/PayPal), sales tax, legal pages, and launch."
  canonical={`${SITE_URL}/docs/onboarding/ecommerce-usa`}
  currentPage="onboarding-usa"
  currentParent="docs"
>
  <DocsShell current="/docs/onboarding/ecommerce-usa">
    <OnboardingGuide
      guide={usaGuide}
      otherHref="/docs/onboarding/ecommerce-india"
      otherLabel="India"
    />
  </DocsShell>
</BaseLayout>
