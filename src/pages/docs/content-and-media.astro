---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLayout from '../../components/docs/DocLayout.astro';
import DocsShell from '../../components/docs/DocsShell.astro';
import { contentMedia } from '../../data/docs';
import { SITE_URL } from '../../config';
---

<BaseLayout
  recaptcha={false}
  title="Preparing and Submitting Your Content and Media | Uxory Docs"
  description="What to gather for your website project, which file formats to use, and how to name, organise, and send your content and media so our developers can use it right away."
  canonical={`${SITE_URL}/docs/content-and-media`}
  currentPage="docs-content-media"
  currentParent="docs"
>
  <DocsShell current="/docs/content-and-media">
    <DocLayout doc={contentMedia} />
  </DocsShell>
</BaseLayout>
