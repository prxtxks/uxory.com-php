---
import BaseLayout from '../../layouts/BaseLayout.astro';
import DocLayout from '../../components/docs/DocLayout.astro';
import { legalIndia } from '../../data/docs';
import { SITE_URL } from '../../config';
---

<BaseLayout
  recaptcha={false}
  title="Drafting Legal Pages for Your Website (India) | Uxory Docs"
  description="A plain-language guide to the legal pages Indian websites need: privacy policy, terms, refund and shipping policies, DPDP Act basics, and when to involve a lawyer."
