---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImageCompressor from '../../components/tools/ImageCompressor.tsx';
import { SITE_URL } from '../../config';

const structuredData = `
{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Uxory Image Optimizer",
  "url": "${SITE_URL}/tools/image-optimizer",
  "applicationCategory": "MultimediaApplication",
  "operatingSystem": "Any (web browser)",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Free online image optimizer. Compress and resize JPG, PNG and WebP images directly in your browser — no upload, no account, completely private."
}
`;
---

<BaseLayout
  title="Free Image Optimizer — Compress JPG, PNG & WebP | Uxory"
  description="Optimize and resize JPG, PNG and WebP images for free, right in your browser. No upload, no sign-up, no watermark — your images never leave your device."
  canonical={`${SITE_URL}/tools/image-optimizer`}
  currentPage="image-optimizer"
  currentParent="tools"
  structuredData={structuredData}
>
  <div class="relative overflow-hidden">
    <!-- Same hero gradient used on the homepage / website-dev hero -->
    <div
      id="hero-gradient-wrapper"
      class="absolute w-full h-full top-0 left-0 -z-10 blur-[60px] scale-90 pointer-events-none overflow-hidden"
    >
      <img
        src="/images/hero-gradient-background.png"
        alt=""
        id="hero-gradient"
        class="absolute left-1/2 top-[30%] -translate-x-1/2 -translate-y-1/2"
      />
    </div>

    <section class="pt-[120px] md:pt-[160px] pb-8 md:pb-10 relative overflow-hidden">
      <div class="container">
        <div class="reveal-me text-center max-w-2xl mx-auto">
          <p class="font-satoshi text-sm font-normal leading-6 tracking-[3px] uppercase mb-4">
            Free Tools
          </p>
          <h2 class="font-normal text-appear">
            Image
            <span class="font-instrument italic">Optimizer</span>
          </h2>
          <p class="mt-5 text-secondary/70 dark:text-backgroundBody/70 text-lg">
            Shrink JPG, PNG and WebP images without losing visible quality. Fast, free, and
            100% private — everything runs in your browser.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden">
      <div class="container">
        <ImageCompressor client:load />
      </div>
    </section>
  </div>
</BaseLayout>
