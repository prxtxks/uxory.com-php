---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Socials from '../components/Socials.astro';
import Blog from '../components/Blog.astro';

const structuredData = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://uxory.in/#organization",
        "name": "Uxory",
        "url": "https://uxory.in",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://uxory.in/#logo",
          "url": "https://uxory.in/images/logo.png",
          "contentUrl": "https://uxory.in/images/logo.png",
          "width": 512,
          "height": 512
        },
        "sameAs": [
          "https://www.linkedin.com/company/uxory/",
          "https://www.instagram.com/uxoryllc/"
        ]
      },
      {
        "@type": "Service",
        "@id": "https://uxory.in/mobile-app-development",
        "name": "Mobile App Development Services",
        "description": "Custom mobile app development services tailored for businesses seeking fast, scalable, and modern mobile solutions. We build iOS, Android, and cross-platform apps with scalable architecture, production-ready code, and seamless UI/UX.",
        "provider": {
          "@id": "https://uxory.in/#organization"
        },
        "url": "https://uxory.in/mobile-app-development",
        "serviceType": "Mobile App Development, iOS Development, Android Development, Cross-Platform Apps, MVPs",
        "areaServed": [
          {
            "@type": "Country",
            "name": "United States"
          },
          {
            "@type": "Country",
            "name": "India"
          }
        ],
        "offers": {
          "@type": "Offer",
          "description": "Custom web and mobile app development services tailored to your business needs"
        }
      },
      {
        "@type": "WebPage",
        "@id": "https://uxory.in/mobile-app-development",
        "url": "https://uxory.in/mobile-app-development",
        "name": "Mobile App Development Services | Uxory",
        "description": "Custom mobile app development by Uxory. We build fast, scalable iOS and Android apps tailored to your business needs.",
        "isPartOf": {
          "@id": "https://uxory.in/#website"
        },
        "about": {
          "@id": "https://uxory.in/mobile-app-development"
        },
        "primaryImageOfPage": {
          "@id": "https://uxory.in/#logo"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://uxory.in/#website",
        "url": "https://uxory.in",
        "name": "Uxory",
        "publisher": {
          "@id": "https://uxory.in/#organization"
        }
      }
    ]
  }`;
---

<BaseLayout
  title="Mobile App Development Services | Uxory"
  description="Custom mobile app development by Uxory. We build fast, scalable iOS and Android apps tailored to your business needs - built for performance, security, and growth."
  currentPage="mobile-app-dev"
  currentParent="services"
  structuredData={structuredData}
>


<!--=====================================
   Hero Section with Gradient
======================================-->
<section
  class="pt-[137px] md:pt-[160px] xl:pt-[180px] pb-20 md:pb-[100px] relative overflow-hidden"
>
  <!-- Gradient Background Wrapper -->
  <div
    id="hero-gradient-wrapper"
    class="absolute w-full h-full top-0 left-0 -z-10 blur-[35px] md:blur-[60px]"
  >
    <img
      src="images/hero-gradient-background.png"
      alt="hero-gradient-background"
      id="hero-gradient"
      class="absolute left-1/2 top-1/2 -translate-x-1/2 max-md:-translate-y-[60%] md:-translate-y-1/2"
    />
  </div>

  <!-- Main Content Container -->
  <div class="container reveal-me">
    <div class="text-center">
      

      <!-- Hero Heading -->
      <h2 class="font-medium mb-3 lg:leading-[1.08]">
        Turn your vision into <br class="hidden lg:block" />
        a high performing app.
      </h2>

      <!-- Hero Description -->
      <p class="mb-8 md:mb-14 xl:mb-[76px] max-w-xl lg:max-w-[750px] mx-auto">
        We specialize in AI-driven, user-centric, scalable we and mobile app
        solutions designed to solve real business problems.
      </p>

      <!-- CTA Buttons -->
      <ul class="flex justify-center list-none mt-14">
      <div
        class="flex w-full md:w-auto p-3 group bg-primary bg-opacity-30 gap-3 justify-between items-center backdrop-blur-2xl max-w-[320px] md:max-w-[320px]"
      >
        <div>
          <h6 class="text-sm font-satoshi font-bold text-black dark:text-white">
            Schedule a Free Meeting
          </h6>
          <p class="text-sm text-black dark:text-white">Few spots left this month</p>
        </div>
          <a href="calendly">
            <figure
              class="bg-primary w-[44px] h-[44px] cursor-pointer relative overflow-hidden"
            >
              <img
                src="images/icons/hyper-arrow-new.svg"
                alt="Arrow Icon"              />
            </figure>
          </a>
      </div>
    </ul>

    </div>
  </div>
</section>


<!-- ==============================
social-proof 
============================== -->

<section class="-z-0">
  <div class="container">
    <div class="relative reveal-me-2">
      <div class="z-50 flex items-center justify-center">
        <img
          src="images/app-sample.webp"
          alt="social-proof"
          class="inline-block dark:hidden"
        />
        <img
          src="images/app-sample.webp"
          alt="social-proof"
          class="dark:inline-block hidden"
        />
      </div>
    </div>
  </div>
</section>


<!-- ==============================
client-success-stories
============================== -->
<section
  class="-mt-[160px] sm:-mt-[250px] md:-mt-[350px] lg:-mt-[450px] z-[2000] relative pt-28 md:pt-32 lg:pt-44 xl:pt-[200px] pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] bg-backgroundBody dark:bg-dark overflow-hidden"
>
  <div class="container">
    <!-- Section Header -->
    <div
      class="flex flex-col md:flex-row gap-x-10 gap-y-4 justify-center lg:justify-between items-start mb-9 lg:mb-16"
    >
      <!-- Title Area -->
      <div class="flex-1 md:self-start">
        <h3 class="text-appear lg:leading-[1.1]">
          <i class="font-instrument">Proven results </i
          ><br class="hidden lg:block" />
          trusted by clients
        </h3>
      </div>

      <!-- Description -->
      <div class="w-full md:max-w-72 lg:max-w-[470px] self-start md:self-end">
        <p class="text-appear max-w-lg md:text-right md:place-self-end">
        We enable businesses to launch faster, scale smarter, and operate better.
        </p>
      </div>
    </div>
    <!-- Counter section -->
    <div class="grid grid-cols-12 gap-8 justify-items-center mb-14 lg:mb-20">
      <!-- 1 -->
      <div
        class="border-y dark:border-dark py-5 flex flex-col md:flex-row justify-center md:justify-between items-center md:items-start w-full sm:min-w-[355px] lg:min-w-[300px] xl:min-w-[355px] reveal-me col-span-12 md:col-span-6 lg:col-span-4"
        id="counter"
      >
        <h2 class="md:min-w-[170px] font-instrument">
          <span class="counter" data-value="60"></span>+
        </h2>
        <p class="text-lg">Successful app launches</p>
      </div>
      <!-- 2 -->
      <div
        class="border-y dark:border-dark py-5 flex flex-col md:flex-row justify-center md:justify-between items-center md:items-start w-full sm:min-w-[355px] lg:min-w-[300px] xl:min-w-[355px] reveal-me col-span-12 md:col-span-6 lg:col-span-4"
        id="counter"
      >
        <h2 class="md:min-w-[170px] font-instrument">
          <span class="counter" data-value="5"></span>+
        </h2>
        <p class="text-lg">Years of experience</p>
      </div>
      <!-- 3 -->
      <div
        class="border-y dark:border-dark py-5 flex flex-col md:flex-row justify-center md:justify-between items-center md:items-start w-full sm:min-w-[355px] lg:min-w-[300px] xl:min-w-[355px] reveal-me col-span-12 md:col-span-6 lg:col-span-4"
        id="counter"
      >
        <h2 class="md:min-w-[170px] font-instrument">
          <span class="counter" data-value="4.8"></span>
          +
        </h2>
        <p class="text-lg">Star rating from global clients</p>
      </div>
    </div>

    <!-- User Review -->
    <style is:global>
      /* Equal-height testimonial cards regardless of text length */
      .user-swiper-v2 .swiper-slide { height: auto; }
      .user-swiper-v2 .swiper-slide > .sets-apart-card { height: 100%; }
    </style>
    <div class="reveal-me">
      <div class="user-swiper-v2 swiper">
        <div class="swiper-wrapper">
          <!-- Review 1 -->
          <div class="swiper-slide">
            <div class="sets-apart-card p-10 flex gap-3 h-full">
              <div class="hidden md:block flex-grow-0">
                <span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="60"
                    height="60"
                    viewBox="0 0 60 60"
                    fill="none"
                  >
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M23.8286 6V16.9714C21.3264 16.9714 16.9186 17.1793 16.9184 27.1958V32.4H27.6V54H6V32.4V27.1958C6 19.3208 8.03795 13.4729 12.4905 9.81413C15.5705 7.28323 19.2195 6 23.8286 6ZM50.229 6V16.9714C47.7268 16.9714 43.319 17.1793 43.3187 27.1958V32.4H54.0004V54H32.4004V32.4V27.1958C32.4004 19.3208 34.4383 13.4729 38.8909 9.81413C41.9709 7.28323 45.6199 6 50.229 6Z"
                      class="dark:fill-backgroundBody fill-secondary"
                      fill-opacity="0.1"
                    />
                  </svg>
                </span>
              </div>
              <div class="flex-1">
                <p
                  class="text-base md:text-xl italic md:leading-[1.5] mb-[30px]"
                >
                  Scalable SaaS product build
                </p>
                <h3 class="text-xl md:text-[30px] md:leading-9 mb-10">
                  Uxory helped us turn a rough idea into a production-ready SaaS platform. The architecture is clean, the app is fast and scalable.
                </h3>
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-3">
                    <div>
                      <h4 class="text-lg md:text-2xl md:leading-[1.2]">
                        Jason Miller
                      </h4>
                      <p class="text-sm leading-5 font-light">Founder, B2B SaaS Platform</p>
                    </div>
                  </div>
                  <div class="self-end max-xs:hidden">
                    <span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="60"
                        height="60"
                        viewBox="0 0 60 60"
                        fill="none"
                      >
                        <path
                          fill-rule="evenodd"
                          clip-rule="evenodd"
                          d="M36.1714 54L36.1714 43.0286C38.6736 43.0286 43.0814 42.8207 43.0816 32.8042L43.0816 27.6L32.4 27.6L32.4 6L54 6L54 27.6L54 32.8042C54 40.6792 51.9621 46.5271 47.5095 50.1859C44.4295 52.7168 40.7805 54 36.1714 54ZM9.77104 54L9.77104 43.0286C12.2732 43.0286 16.681 42.8207 16.6812 32.8042L16.6812 27.6L5.99961 27.6L5.99961 6L27.5996 6L27.5996 27.6L27.5996 32.8042C27.5996 40.6792 25.5617 46.5271 21.1091 50.1859C18.0291 52.7168 14.3801 54 9.77104 54Z"
                          class="dark:fill-backgroundBody fill-secondary"
                          fill-opacity="0.1"
                        />
                      </svg>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <!-- Review 2 -->
          <div class="swiper-slide">
            <div class="sets-apart-card p-10 flex gap-3 h-full">
              <div class="hidden md:block flex-grow-0">
                <span>
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="60"
                    height="60"
                    viewBox="0 0 60 60"
                    fill="none"
                  >
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M23.8286 6V16.9714C21.3264 16.9714 16.9186 17.1793 16.9184 27.1958V32.4H27.6V54H6V32.4V27.1958C6 19.3208 8.03795 13.4729 12.4905 9.81413C15.5705 7.28323 19.2195 6 23.8286 6ZM50.229 6V16.9714C47.7268 16.9714 43.319 17.1793 43.3187 27.1958V32.4H54.0004V54H32.4004V32.4V27.1958C32.4004 19.3208 34.4383 13.4729 38.8909 9.81413C41.9709 7.28323 45.6199 6 50.229 6Z"
                      class="dark:fill-backgroundBody fill-secondary"
                      fill-opacity="0.1"
                    />
                  </svg>
                </span>
              </div>
              <div class="flex-1">
                <p
                  class="text-base md:text-xl italic md:leading-[1.5] mb-[30px]"
                >
                  Marketplace app done right
                </p>
                <h3 class="text-xl md:text-[30px] md:leading-9 mb-10">
                  We needed a two-sided marketplace with payments and dashboards. Uxory delivered exactly that.
                </h3>
                <div class="flex justify-between items-center">
                  <div class="flex items-center gap-3">
                    <div>
                      <h4 class="text-lg md:text-2xl md:leading-[1.2]">
                        Rohit Kulkarni
                      </h4>
                      <p class="text-sm leading-5 font-light">
                        Product Lead, Service Marketplace App
                      </p>
                    </div>
                  </div>
                  <div class="self-end max-xs:hidden">
                    <span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="60"
                        height="60"
                        viewBox="0 0 60 60"
                        fill="none"
                      >
                        <path
