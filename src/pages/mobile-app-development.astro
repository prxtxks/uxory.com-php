        Smart automations and chatbots that reduce manual work and improve response time.
        </p>
        <ul class="pl-4 mt-6">
          <li class="card-list-item list-disc text-base leading-relaxed">
          AI & rule-based bots
          </li>
          <li class="card-list-item list-disc text-base leading-relaxed">
          Lead & support automation
          </li>
          <li class="card-list-item list-disc text-base leading-relaxed">
          Tool integrations
          </li>
        </ul>
      </div>

      <!-- Backend Development Card -->
      <div class="sets-apart-card reveal-me p-8">
        <div class="mb-10">
          <h5 class="max-sm:text-3xl text-dark dark:text-backgroundBody">
          Backend & APIs
          </h5>
        </div>
        <p class="text-dark/70 dark:text-backgroundBody/70">
        Robust backend systems that power reliable, secure applications.
        </p>
        <ul class="pl-4 mt-6">
          <li class="card-list-item list-disc text-base leading-relaxed">
          APIs & databases
          </li>
          <li class="card-list-item list-disc text-base leading-relaxed">
          Authentication & security
          </li>
          <li class="card-list-item list-disc text-base leading-relaxed">
          Cloud-ready systems
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>


<!-- =======================
download-our-apps 
========================= -->
<section
  id="download-apps-section"
  class="mb-14 pt-14 max-sm:pb-5 md:mb-16 md:pt-16 lg:mb-[88px] lg:pt-[88px] xl:mb-[100px] xl:pt-[100px] mt-14 md:mt-16 lg:mt-[88px] xl:mt-[100px] bg-secondary"
>
  <div class="container">
    <div
      class="flex flex-col md:flex-row justify-center gap-y-6 md:justify-start"
    >
      <figure class="flex-1 reveal-me">
        <img
          src="images/download-app.webp"
          alt="download-app-thumbnail"
          width="462"
          height="492"
        />
