---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Socials from '../components/Socials.astro';
import Blog from '../components/Blog.astro';

const structuredData = `{
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Organization",
        "@id": "https://uxory.com/#organization",
        "name": "Uxory",
        "url": "https://uxory.com",
        "logo": {
          "@type": "ImageObject",
          "@id": "https://uxory.com/#logo",
          "url": "https://uxory.com/images/logo.png",
          "contentUrl": "https://uxory.com/images/logo.png",
          "width": 512,
          "height": 512
        },
        "sameAs": [
          "https://www.linkedin.com/company/uxory/",
          "https://www.instagram.com/uxoryllc/"
        ]
      },
      {
        "@type": "Service",
        "@id": "https://uxory.com/smb-hosting",
        "name": "SMB Website Hosting Services",
        "description": "Managed website hosting for small and medium businesses. We configure, monitor, and maintain your hosting environment on trusted cloud infrastructure, ensuring consistent performance, uptime, and peace of mind. Includes SSL certificates, daily backups, security hardening, and premium support.",
        "provider": {
          "@id": "https://uxory.com/#organization"
        },
        "url": "https://uxory.com/smb-hosting",
        "serviceType": "Website Hosting, Managed Hosting, VPS Hosting, Cloud Hosting",
        "areaServed": [
          {
            "@type": "Country",
            "name": "United States"
          },
          {
            "@type": "Country",
            "name": "India"
          }
        ],
        "offers": {
          "@type": "Offer",
          "description": "Managed website hosting solutions for small and medium businesses"
        }
      },
      {
        "@type": "WebPage",
        "@id": "https://uxory.com/smb-hosting",
        "url": "https://uxory.com/smb-hosting",
        "name": "SMB Website Hosting | Managed Hosting Services | Uxory",
        "description": "Reliable, secure, and fully managed website hosting for small and medium businesses. Fast load times, SSL certificates, daily backups, and premium support included.",
        "isPartOf": {
          "@id": "https://uxory.com/#website"
        },
        "about": {
          "@id": "https://uxory.com/smb-hosting"
        },
        "primaryImageOfPage": {
          "@id": "https://uxory.com/#logo"
        }
      },
      {
        "@type": "WebSite",
        "@id": "https://uxory.com/#website",
        "url": "https://uxory.com",
        "name": "Uxory",
        "publisher": {
          "@id": "https://uxory.com/#organization"
        }
      }
    ]
  }`;
---

<BaseLayout
  title="SMB Website Hosting | Managed Hosting Services | Uxory"
  description="Reliable, secure, and fully managed website hosting for small and medium businesses. Fast load times, SSL certificates, daily backups, and premium support included."
  currentPage="smb-hosting"
  currentParent="pricing"
  structuredData={structuredData}
>


<!--=====================================
   Hero Section
======================================-->
<section
  class="pt-[120px] sm:pt-[135px] md:pt-[150px] lg:pt-44 xl:pt-[200px] pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden"
>
  <!-- Gradient Background Effect -->
  <div
    id="hero-gradient-wrapper"
    class="absolute w-full h-fw-full top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 -z-10 blur-[60px] scale-90"
  >
    <img
      src="images/hero-gradient-background-02.png"
      alt="hero-gradient-background"
      id="hero-gradient"
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
    />
  </div>

  <!-- Hero Content -->
  <div class="container">

    <h2 class="font-medium text-center reveal-me">
      Reliable Website Hosting for SMBs
    </h2>
    <p class="max-w-3xl text-center mx-auto mt-3 text-appear">
      Fast, secure, and fully managed hosting, without infrastructure headaches.
    </p>

    <!-- Hero Buttons -->
    <ul class="flex justify-center list-none mt-14 reveal-me">
      <li class="text-center">
        <a
          href="#section-pricing"
          class="rv-button rv-button-primary inline-block cursor-pointer"
          id="hero-button-02"
        >
          <div class="rv-button-top">
            <span>View Hosting Plans</span>
          </div>
          <div class="rv-button-bottom">
            <span class="text-nowrap">View Hosting Plans</span>
          </div>
        </a>
      </li>
    </ul>
  </div>
</section>

<!--==================================
   About Description Section Area
===================================-->
<section
  class="pt-14 md:pt-16 lg:pt-[88px] xl:pt-[100px] md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden"
>
  <div class="container reveal-me">
    <p
          class="reveal-text-2 text-2xl lg:text-3xl text-secondary/90 dark:text-backgroundBody/70 text-left font-normal lg:leading-[1.2] lg:tracking-[0.72px] pb-10 sm:pb-20"
        >
      Uxory offers managed website hosting for small and medium businesses that need reliability, security, and support without managing servers themselves.
       We configure, monitor, and maintain your hosting environment on trusted cloud infrastructure, ensuring consistent performance, uptime, and 
       peace of mind as your business grows.
  </p>
  </div>
</section>

<!--=====================================
   Why Choose Rivor Section
======================================-->
<section
  class="pt-14 md:pt-16 lg:pt-[88px] xl:pt-[100px] pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden"
>
  <div class="container">
    <!-- Section Header -->
    <div class="text-center mb-8 md:mb-14">
      <h2 class="mt-3 text-appear">
        Why Choose<i class="font-instrument">Uxory?</i>
      </h2>
    </div>

    <!-- Content Area -->
    <div class="flex flex-col-reverse md:flex-row gap-y-8 gap-x-[30px]">
      <div class="md:w-1/2 [&>*]:border-b">
        <div class="reveal-me py-3.5 lg:py-[30px] pr-[30px]">
          <h5>SMB-Focused Hosting</h5>
          <p class="top-3 tracking-[ 0.32px] leading-[1.6] text-base">
            Built for real business websites
          </p>
        </div>
        <div class="reveal-me py-3.5 lg:py-[30px] pr-[30px]">
          <h5>Fully Managed Setup</h5>
          <p class="mt-3 tracking-[0.32px] leading-[1.6] text-base">
            We handle configuration and upkeep
          </p>
        </div>
        <div class="reveal-me py-3.5 lg:py-[30px] pr-[30px]">
          <h5>Performance Optimized</h5>
          <p class="mt-3 tracking-[0.32px] leading-[1.6] text-base">
            Fast load times, stable uptime
          </p>
        </div>
        <div class="reveal-me py-3.5 lg:py-[30px] pr-[30px]">
          <h5>Security Included</h5>
          <p class="mt-3 tracking-[0.32px] leading-[1.6] text-base">
            SSL, backups, basic monitoring
          </p>
        </div>
        <div class="reveal-me py-3.5 lg:py-[30px] pr-[30px]">
          <h5>Human Support</h5>
          <p class="mt-3 tracking-[0.32px] leading-[1.6] text-base">
            Direct access to real engineers
          </p>
        </div>
      </div>
      <figure class="md:w-1/2 reveal-me" style="border-radius: 16px; overflow: hidden;">
        <!-- Replace with your image path -->
        <img
          src="images/services/why-us-hosting.jpg"
          alt="Managed Website Hosting Services"
          class="w-full h-full"
        />
      </figure>
    </div>

    <!-- rv-button-primary -->
    <!-- <ul class="flex justify-center mt-14 reveal-me">
      <li>
        <a href="contact" class="rv-button rv-button-sm rv-button-primary">
          <div class="rv-button-top">
            <span>Let's Talk</span>
          </div>
          <div class="rv-button-bottom">
            <span>Let's Talk</span>
          </div>
        </a>
      </li>
    </ul> -->
  </div>
</section>


<!-- ================================
Pricing Section
================================ -->
<section id="section-pricing"
  class="max-sm:pt-16 lg:pt-[88px] xl:pt-[100px] pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden"
>
<!-- Section Header -->
  <div class="container">

    <div class="mb-7 lg:mb-14 text-center">
      <h2 class="mb-3 text-center text-appear">
        Pricing
        <i class="font-instrument">plan </i>
      </h2>
      <p class="max-w-3xl text-appear mx-auto">
        The essentials plan is exclusive to websites delivered by Uxory. 
      </p>
    </div>

    <div>
      <div>
        <div class="flex flex-row items-center justify-center gap-6 reveal-me">
          <p
            class="overflow-hidden text-ellipsis flex gap-2.5 font-satoshi text-[17px] font-normal leading-[1.4] tracking-[0.34px]"
          >
            <span> Save up to 30% </span>
          </p>
          <div class="border-4 border-primary/20 p-[2px] rounded-full">
            <div
              id="toggle"
              class="relative w-[177px] h-12 bg-primary rounded-full p-[3px] pb-1 cursor-pointer"
            >
              <div
                class="toggle-slider absolute w-[calc(50%-1px)] h-[calc(97%-4px)] bg-black rounded-full"
              ></div>

              <div class="relative flex h-full">
                <div
                  id="monthlyOption"
                  class="toggle-option flex-1 flex items-center justify-center text-sm font-medium text-secondary z-10"
                >
                  Monthly
                </div>

                <div
                  id="yearlyOption"
                  class="toggle-option flex-1 flex items-center justify-center text-sm font-medium text-secondary z-10"
                >
                  Yearly
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div
        class="grid lg:grid-cols-2 justify-center gap-x-10 mt-10 md:mt-20 gap-y-10 reveal-me"
      >
        <div
          class="sets-apart-card px-[30px] pt-8 md:pt-20 pb-[30px] relative overflow-hidden"
        >
          <img
            src="/images/pricing-gradient-bg-1.png"
            class="absolute top-0 left-0"
            alt="Gradient color"
          />
          <div>
            <div>
              <h6 class="mb-4 max-md:text-3xl">Custom Hosting</h6>
              <p class="text-base">
                Tailored and managed hosting solutions designed around your exact needs.
              </p>
            </div>

            <div
              class="flex flex-col md:flex-row items-start md:items-end gap-y-3 md:gap-y-6 gap-x-10 py-8"
            >
              <p
                class="text-6xl leading-[60px] text-secondary dark:text-backgroundBody"
              >
                Custom
              </p>
              <p class="text-sm leading-[18px] tracking-[-0.2px]">
                Flexible payment schedule, <br />
                50% down payment
              </p>
            </div>

            <a href="./calendly" class="rv-button rv-button-secondary">
              <div class="rv-button-top">
                <span class="!font-normal"> BOOK INTRO CALL</span>
              </div>
              <div class="rv-button-bottom">
                <span class="!font-normal"> BOOK INTRO CALL</span>
              </div>
            </a>

