---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTA from '../components/CTA.astro';
import Socials from '../components/Socials.astro';
import Blog from '../components/Blog.astro';

const structuredData = `
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://uxory.in/#organization",
      "name": "Uxory",
      "url": "https://uxory.in",
      "logo": {
        "@type": "ImageObject",
        "@id": "https://uxory.in/#logo",
        "url": "https://uxory.in/images/logo.png",
        "contentUrl": "https://uxory.in/images/logo.png",
        "width": 512,
        "height": 512
      },
      "sameAs": [
        "https://www.linkedin.com/company/uxory/",
        "https://www.instagram.com/uxoryllc/"
      ],
      "description": "Uxory is a software solutions company offering custom software development, website development, automation, and AI solutions with a focus on innovation, transparency, and client growth."
    },
    {
      "@type": "AboutPage",
      "@id": "https://uxory.in/about-us#webpage",
      "url": "https://uxory.in/about-us",
      "name": "About Us | Uxory",
      "description": "Learn about Uxory, a software solutions company specializing in custom software development, website development, automation, and AI solutions for modern businesses.",
      "isPartOf": {
        "@id": "https://uxory.in/#website"
      },
      "about": {
        "@id": "https://uxory.in/#organization"
      },
      "primaryImageOfPage": {
        "@id": "https://uxory.in/#logo"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://uxory.in/#website",
      "url": "https://uxory.in",
      "name": "Uxory",
      "publisher": {
        "@id": "https://uxory.in/#organization"
      }
    }
  ]
}
`;
---

<BaseLayout
  title="About Us | Uxory - Software & Automation Solutions"
  description="Learn about Uxory, a software solutions company specializing in custom software development, website development, automation, and AI solutions for modern businesses."
  currentPage="about-us"
  currentParent="about"
  structuredData={structuredData}
>

<!--=====================================
   Hero Section
======================================-->
<section class="pt-32 md:pt-44 lg:pt-[190px] pb-10 md:pb-14 relative overflow-hidden">
  <div
    id="hero-gradient-wrapper"
    class="absolute w-full h-full top-0 left-0 -z-10 blur-[35px] md:blur-[60px] sm:scale-[0.1] bg-blend-multiply md:scale-75"
  >
    <img
      src="/images/hero-gradient-background.png"
      alt="hero-gradient-background"
      id="hero-gradient"
      class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-[45%]"
    />
  </div>

  <div class="container px-5 md:px-8">
    <div class="reveal-me mx-auto max-w-3xl text-center">
      <p class="font-satoshi mb-4 text-sm font-normal uppercase leading-6 tracking-[3px]">
        About Uxory
      </p>
      <h1 class="hero-title font-medium text-appear text-[42px] leading-[1.14] md:text-[60px] xl:text-[68px]">
        Software that works as hard as you do
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg text-secondary/70 dark:text-backgroundBody/70 md:text-xl">
        We design, build, and care for intelligent software - websites, web apps, automation, and
        AI - for businesses that want systems that simply work.
      </p>

      <!-- Trust chips -->
      <div class="reveal-me mt-9 flex flex-wrap items-center justify-center gap-2.5">
        <span class="inline-flex items-center gap-2 rounded-full border border-secondary/12 bg-white/50 px-4 py-2 text-sm text-secondary/70 backdrop-blur-sm dark:border-white/12 dark:bg-white/[0.04] dark:text-backgroundBody/70">
          <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V7l7-4 7 4v14M9 9h.01M15 9h.01M9 13h.01M15 13h.01M9 17h.01M15 17h.01"/></svg>
          Registered in the USA &amp; India
        </span>
        <span class="inline-flex items-center gap-2 rounded-full border border-secondary/12 bg-white/50 px-4 py-2 text-sm text-secondary/70 backdrop-blur-sm dark:border-white/12 dark:bg-white/[0.04] dark:text-backgroundBody/70">
          <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 010 18 15 15 0 010-18z"/></svg>
          Clients in 4 countries
        </span>
        <a href="/reviews" class="group inline-flex items-center gap-2 rounded-full border border-primary/25 bg-primary/[0.07] px-4 py-2 text-sm font-medium text-secondary transition-colors hover:border-primary/60 dark:text-backgroundBody">
          <svg class="h-4 w-4 text-primary" viewBox="0 0 20 20" fill="currentColor"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.37 1.12l1.07 3.29c.3.92-.75 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.17 0l-2.8 2.03c-.79.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12L2.83 8.72c-.78-.57-.38-1.81.59-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg>
          <span><span class="text-primary">5.0</span> verified client reviews</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!--=====================================
   Our story
======================================-->
<section class="py-14 md:py-20 lg:py-[100px]">
  <div class="container px-5 md:px-8">
    <div class="grid items-start gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="reveal-me">
        <p class="font-satoshi mb-3 text-sm uppercase tracking-[3px] text-primary">Who we are</p>
        <h2 class="text-appear-2 text-3xl font-normal leading-tight md:text-[44px]">
          A studio, not a
          <span class="font-instrument italic">factory</span>
        </h2>
      </div>
      <div class="reveal-me space-y-5 text-lg leading-relaxed text-secondary/75 dark:text-backgroundBody/75">
        <p>
          Uxory is a software and AI studio with registered companies in the United States and
          India. We take on a small number of projects at a time and go deep on each one -
          understanding the business first, then building the system that fits it.
        </p>
        <p>
          From luxury e-commerce and hotel booking engines to AI underwriting platforms, everything
          is designed, developed, and maintained in-house. The people who scope your project are
          the ones who build it.
        </p>
      </div>
    </div>
  </div>
</section>

<!--=====================================
   What we build - minimal row index
======================================-->
<section class="py-14 md:py-20 lg:py-[100px]">
  <div class="container px-5 md:px-8">
    <div class="reveal-me mb-10 md:mb-14">
      <p class="font-satoshi mb-3 text-sm uppercase tracking-[3px] text-primary">What we build</p>
      <h2 class="text-appear-2 text-3xl font-normal md:text-[44px]">
        One team, <span class="font-instrument italic">end to end</span>
      </h2>
    </div>

    <div class="reveal-me divide-y divide-secondary/10 border-y border-secondary/10 dark:divide-white/10 dark:border-white/10">
      {
        [
          ['/website-dev', 'Websites & E-commerce', 'High-performance sites and stores that convert.'],
          ['/web-app-and-saas-dev', 'Web Apps & SaaS', 'From MVP to scale, on modern stacks.'],
          ['/mobile-app-development', 'Mobile Apps', 'iOS and Android from one codebase.'],
          ['/process-automation', 'AI Agents & Automation', 'Assistants and workflows that kill busywork.'],
          ['/smb-hosting', 'Managed Hosting & Care', 'Monitoring, backups, and a team on call.'],
          ['/get-quote', 'Instant Estimate', 'Know your price before you commit.'],
        ].map(([href, title, desc]) => (
          <a href={href} class="group flex items-center justify-between gap-6 py-5 transition-colors md:py-6">
            <span class="flex flex-col gap-1 md:flex-row md:items-baseline md:gap-6">
              <span class="text-xl font-medium text-secondary transition-colors group-hover:text-primary dark:text-backgroundBody md:text-2xl md:min-w-[320px]">
                {title}
              </span>
              <span class="text-[15px] text-secondary/55 dark:text-backgroundBody/55">{desc}</span>
            </span>
            <span class="shrink-0 text-secondary/30 transition-all duration-300 group-hover:translate-x-1.5 group-hover:text-primary dark:text-backgroundBody/30">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6" />
              </svg>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<!--=====================================
   The team
======================================-->
<section class="py-14 md:py-20 lg:py-[100px]">
  <div class="container px-5 md:px-8">
    <div class="grid items-start gap-10 lg:grid-cols-[1fr_1.4fr] lg:gap-16">
      <div class="reveal-me">
        <p class="font-satoshi mb-3 text-sm uppercase tracking-[3px] text-primary">The team</p>
        <h2 class="text-appear-2 text-3xl font-normal leading-tight md:text-[44px]">
          The people behind
          <span class="font-instrument italic">the work</span>
        </h2>
        <p class="mt-5 max-w-md text-lg text-secondary/70 dark:text-backgroundBody/70">
          No account managers in between. When you work with Uxory, you talk directly to the
          people designing and building your project.
        </p>
      </div>

      <div class="reveal-me divide-y divide-secondary/10 dark:divide-white/10">
        {
          [
            ['Engineers and designers, one roof', 'Product, design, development, and hosting handled by a single in-house team - nothing is passed to outsourcing chains.'],
            ['Across the US and India', 'Our team works from both sides of the world, which means overlap with your timezone and progress while you sleep.'],
            ['Small on purpose', 'We keep the team and the project count deliberately small, so senior people do the actual work - not just the sales call.'],
          ].map(([title, desc]) => (
            <div class="py-6 first:pt-0 last:pb-0">
              <p class="text-xl font-medium text-secondary dark:text-backgroundBody">{title}</p>
              <p class="mt-2 text-[15px] leading-relaxed text-secondary/60 dark:text-backgroundBody/60">{desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<!--=====================================
   Why clients stay - three plain points
======================================-->
<section class="py-14 md:py-20 lg:py-[100px]">
  <div class="container px-5 md:px-8">
    <div class="reveal-me mb-10 text-center md:mb-14">
      <p class="font-satoshi mb-3 text-sm uppercase tracking-[3px] text-primary">Why clients stay</p>
      <h2 class="text-appear-2 text-3xl font-normal md:text-[44px]">
        Three promises we <span class="font-instrument italic">keep</span>
      </h2>
    </div>

    <div class="grid gap-10 md:grid-cols-3 md:gap-8">
      {
        [
          ['Transparent pricing', 'Public packages and an instant estimator - you see honest numbers before you ever talk to us.'],
          ['One in-house team', 'Design to deployment under one roof. The people who scope your project build it.'],
          ['Support that stays', 'Monitoring, maintenance, and improvements long after launch day - we stay accountable.'],
        ].map(([title, desc], i) => (
          <div class="reveal-me text-center md:text-left">
            <p class="font-satoshi text-sm font-bold tracking-[2px] text-primary">0{i + 1}</p>
            <p class="mt-3 text-xl font-medium text-secondary dark:text-backgroundBody">{title}</p>
            <p class="mt-2 text-[15px] leading-relaxed text-secondary/60 dark:text-backgroundBody/60">{desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!--=====================================
   Tooling strip - compact, subdued
======================================-->
<section class="bg-black py-10 md:py-12 relative overflow-hidden">
  <div class="container px-5 md:px-8">
    <p class="reveal-me mb-6 text-center font-satoshi text-xs uppercase tracking-[3px] text-backgroundBody/40">
      Built with industry-leading tools
    </p>
  </div>

  <div class="marquee-container reveal-me">
    <div class="flex items-center justify-between gap-8 py-2 md:gap-16">
      {
        [1, 2, 3, 4, 5, 6, 7, 8].map((n) => (
          <div class="ml-8 flex h-[40px] w-[80px] items-center justify-center first:md:ml-16">
            <img
              class="max-h-full max-w-full object-contain"
              src={`/images/icons/company/client-${n}.svg`}
              alt="Tool logo"
              loading="lazy"
            />
          </div>
        ))
      }
    </div>
  </div>
</section>

  <CTA />
  <Socials />
  <Blog />

</BaseLayout>
