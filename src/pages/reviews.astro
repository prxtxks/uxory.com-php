---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReviewsApp from '../components/reviews/ReviewsApp.tsx';
import FormFieldStyles from '../components/FormFieldStyles.astro';
import { SITE_URL } from '../config';

// Pull real rating stats at build time so the reviews page can carry an
// AggregateRating in its structured data. Wrapped so a failed/absent DB
// connection never breaks the build — we simply omit the rating.
let aggregateRating: { ratingValue: string; reviewCount: number } | null = null;
try {
  const url = import.meta.env.SUPABASE_URL || process.env.SUPABASE_URL;
  const key = import.meta.env.SUPABASE_SERVICE_KEY || process.env.SUPABASE_SERVICE_KEY;
  if (url && key) {
    const { createClient } = await import('@supabase/supabase-js');
    const sb = createClient(url, key);
    const { data } = await sb.from('reviews').select('rating');
    if (data && data.length > 0) {
      const avg = data.reduce((s, r) => s + (r.rating || 0), 0) / data.length;
      aggregateRating = { ratingValue: avg.toFixed(1), reviewCount: data.length };
    }
  }
} catch {
  aggregateRating = null;
}

const organizationNode: Record<string, unknown> = {
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'Uxory',
  url: `${SITE_URL}/`,
};
if (aggregateRating) {
  organizationNode.aggregateRating = {
    '@type': 'AggregateRating',
    ratingValue: aggregateRating.ratingValue,
    reviewCount: aggregateRating.reviewCount,
    bestRating: '5',
    worstRating: '1',
  };
}

const structuredData = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    organizationNode,
    {
      '@type': 'WebPage',
      '@id': `${SITE_URL}/reviews#webpage`,
      url: `${SITE_URL}/reviews`,
      name: 'Client Reviews | The Uxory Globe',
      description:
        'Read real reviews from Uxory clients. Share your experience working with us.',
      isPartOf: { '@id': `${SITE_URL}/#website` },
    },
  ],
});
---

<BaseLayout
  title="Client Reviews | The Uxory Globe"
  description="Read real reviews from Uxory clients. Share your experience working with us - no account needed. Star ratings, threaded discussions, and honest feedback."
  currentPage="reviews"
  currentParent="about"
  structuredData={structuredData}
>

  <style is:global>
    /* Card surfaces reused by the React reviews island */
    .review-card {
      border-radius: 16px;
      background-color: #F5F7FA;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    :is(:where(.dark) .review-card) { background-color: #1e1e1e; }
    .review-card:hover { transform: translateY(-2px); }

    .review-form-card { border-radius: 16px; background-color: #F5F7FA; }
    :is(:where(.dark) .review-form-card) { background-color: #1e1e1e; }

    .reply-card { border-radius: 12px; background-color: #eef1f5; }
    :is(:where(.dark) .reply-card) { background-color: #171717; }

    .reply-form-card { border-radius: 12px; background-color: #eef1f5; }
    :is(:where(.dark) .reply-form-card) { background-color: #171717; }

    .review-input { border-radius: 10px; background-color: #fff !important; }
    :is(:where(.dark) .review-input) { background-color: #151515 !important; }
    .reply-input { border-radius: 8px; background-color: #fff; }
    :is(:where(.dark) .reply-input) { background-color: #151515; }
  </style>

  <!--=====================================
     Hero Section
  ======================================-->
  <section class="pt-[120px] md:pt-[180px] pb-8 md:pb-10 relative overflow-hidden">
    <div
      id="hero-gradient-wrapper"
      class="absolute w-full h-full top-1/2 left-1/2 -translate-y-1/2 -translate-x-1/2 -z-10 blur-[60px] scale-90"
    >
      <img
        src="/images/hero-gradient-background-02.webp"
        alt=""
        id="hero-gradient"
        class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2"
      />
    </div>

    <div class="container">
      <div class="reveal-me text-center">
        <p class="font-satoshi text-sm font-normal leading-6 tracking-[3px] uppercase mb-4">
          Client Reviews
        </p>
        <h2 class="font-normal text-appear">
          The Uxory Globe
        </h2>
        <p class="mt-5 max-w-lg mx-auto text-secondary/70 dark:text-backgroundBody/70 text-lg">
          Real feedback from real people. No account needed - just your honest experience.
        </p>
      </div>
    </div>
  </section>

  <!--=====================================
     Reviews App (React island)
  ======================================-->
  <section class="pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative overflow-hidden">
    <div class="container">
      <ReviewsApp client:load />
      <FormFieldStyles />
    </div>
  </section>

  <!-- reCAPTCHA temporarily disabled until a valid key is configured.
       Restore this script (and RECAPTCHA_ENABLED in ReviewsApp.tsx) to re-enable. -->
  <!-- <script is:inline src="https://www.google.com/recaptcha/api.js?render=explicit" async defer></script> -->

</BaseLayout>
