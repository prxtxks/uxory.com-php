---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReferForm from '../components/refer/ReferForm.tsx';
import { SITE_URL } from '../config';

const structuredData = `
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Refer & Earn - Uxory",
  "url": "${SITE_URL}/refer",
  "description": "Refer a client to Uxory and earn 10% of their spend, up to $1,000 USD."
}
`;

const steps = [
  { n: '1', title: 'Refer someone', desc: 'Share your email and your referral’s email below. That’s it.' },
  { n: '2', title: 'We build for them', desc: 'We reach out, scope the project, and deliver great work.' },
  { n: '3', title: 'You get paid', desc: 'Earn 10% of what they spend with us - up to $1,000 USD.' },
];
---

<BaseLayout
  recaptcha={false}
  title="Refer & Earn - Get 10% of Your Referral’s Spend | Uxory"
  description="Know someone who needs a website, app or automation? Refer them to Uxory and earn 10% of their spend, up to $1,000 USD."
  canonical={`${SITE_URL}/refer`}
  currentPage="refer"
  structuredData={structuredData}
>
  <div class="relative">
    <!-- Ambient brand gradient -->
    <div class="absolute inset-0 -z-10 overflow-hidden pointer-events-none">
      <div
        class="absolute inset-0"
        style="background: radial-gradient(760px 380px at 50% 0%, rgba(18,216,204,0.22), transparent 65%);"
      ></div>
    </div>

    <!-- Hero -->
    <section class="pt-[120px] md:pt-[160px] pb-6 relative overflow-hidden">
      <div class="container">
        <div class="text-center max-w-2xl mx-auto reveal-me">
          <p class="font-satoshi text-sm tracking-[3px] uppercase mb-4 text-primary">Refer &amp; Earn</p>
          <h1 class="font-normal text-appear text-4xl md:text-6xl leading-tight">
            Earn <span class="text-primary">10%</span> for every client you send us
          </h1>
          <p class="mt-5 text-lg text-secondary/70 dark:text-backgroundBody/70">
            Refer a business that needs a website, app or automation. When they become a client,
            you earn <span class="font-medium">10% of their spend - up to $1,000 USD</span>.
          </p>
        </div>

        <!-- Reward highlight -->
        <div class="mt-10 flex justify-center">
          <div class="inline-flex items-center gap-4 rounded-2xl border border-primary/30 bg-primary/5 px-6 py-4">
            <span class="text-4xl md:text-5xl font-medium text-primary">10%</span>
            <div class="text-left">
              <p class="font-medium">of your referral’s spend</p>
              <p class="text-sm text-secondary/60 dark:text-backgroundBody/60">Capped at $1,000 USD per referral</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- How it works -->
    <section class="py-10">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 max-w-4xl mx-auto">
          {steps.map((s) => (
            <div class="rounded-2xl border border-secondary/10 dark:border-backgroundBody/10 p-6">
              <div class="w-10 h-10 rounded-full bg-primary/15 text-primary flex items-center justify-center font-medium mb-4">
                {s.n}
              </div>
              <h3 class="text-lg font-medium mb-1.5">{s.title}</h3>
              <p class="text-sm text-secondary/70 dark:text-backgroundBody/70 leading-relaxed">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Form -->
    <section class="pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px]">
      <div class="container">
        <div class="text-center mb-8">
          <h2 class="text-2xl md:text-3xl font-normal">Submit your referral</h2>
        </div>
        <ReferForm client:load />

        <p class="max-w-lg mx-auto mt-6 text-center text-xs text-secondary/40 dark:text-backgroundBody/40">
          Reward is paid as 10% of the referred client’s total paid invoices, capped at $1,000 USD,
          after they complete their first project. One reward per newly referred client.
        </p>
      </div>
    </section>
  </div>
</BaseLayout>
