---
import BaseLayout from '../layouts/BaseLayout.astro';
import QuoteWizard from '../components/quote/QuoteWizard.tsx';
import { SITE_URL } from '../config';

const structuredData = `
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Uxory Instant Estimate",
  "url": "${SITE_URL}/get-quote",
  "applicationCategory": "BusinessApplication",
  "operatingSystem": "Any (web browser)",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "description": "Answer a few questions about your website, app, AI bot or automation project and get an instant indicative quote — in INR for India or USD globally."
}
`;
---

<BaseLayout
  title="Instant Project Estimate — Website, App & AI Quotes | Uxory"
  description="Get an instant indicative quote for your website, e-commerce store, mobile app, AI bot or automation project. Answer a few questions — transparent pricing in ₹ or $, emailed to you free."
  canonical={`${SITE_URL}/get-quote`}
  currentPage="get-quote"
  currentParent="pricing"
  structuredData={structuredData}
>
  <div class="relative overflow-hidden">
    <!-- Same hero gradient family as the homepage -->
    <div
      id="hero-gradient-wrapper"
      class="absolute w-full h-full top-0 left-0 -z-10 blur-[60px] scale-90 pointer-events-none overflow-hidden"
    >
      <img
        src="/images/hero-gradient-background.png"
        alt=""
        id="hero-gradient"
        class="absolute left-1/2 top-[25%] -translate-x-1/2 -translate-y-1/2"
      />
    </div>

    <section class="pt-[110px] md:pt-[150px] pb-6 relative">
      <div class="container">
        <div class="reveal-me text-center max-w-2xl mx-auto">
          <p class="font-satoshi inline-flex items-center gap-2 rounded-full border border-secondary/10 bg-white/50 px-4 py-1.5 text-xs font-medium leading-6 tracking-[3px] uppercase mb-6 backdrop-blur-md dark:border-white/10 dark:bg-white/[0.04]">
            <span class="relative flex h-1.5 w-1.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-75"></span>
              <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-primary"></span>
            </span>
            AI-Powered Estimate
          </p>
          <h1 class="font-medium text-appear text-[44px] md:text-[60px] xl:text-[68px] leading-[1.12]">
            Know your price before you commit
          </h1>
          <p class="mt-5 text-secondary/70 dark:text-backgroundBody/70 text-lg md:text-xl">
            No other agency shows you this upfront. Two minutes, honest numbers, zero obligation.
          </p>
        </div>
      </div>
    </section>

    <section class="pb-16 md:pb-24 relative">
      <div class="container">
        <div class="relative mx-auto max-w-3xl">
          <!-- Soft AI glow behind the console -->
          <div
            class="pointer-events-none absolute -inset-x-6 -top-8 bottom-0 -z-10 rounded-[40px] bg-[radial-gradient(60%_50%_at_50%_0%,rgba(18,216,204,0.16),transparent_70%)]"
          >
          </div>
          <div
            class="quote-console relative overflow-hidden rounded-[28px] border border-secondary/10 bg-white/75 p-5 shadow-[0_30px_80px_-40px_rgba(0,0,0,0.35)] backdrop-blur-2xl dark:border-white/[0.08] dark:bg-[#111]/70 dark:shadow-[0_30px_90px_-40px_rgba(0,0,0,0.9)] md:p-9"
          >
            <QuoteWizard client:load />
          </div>
        </div>
        <p class="mt-7 text-center text-xs text-secondary/40 dark:text-backgroundBody/40">
          Estimates are indicative and matched to our public packages · Trusted by clients in 🇮🇳 🇺🇸 🇩🇪 🇳🇵
        </p>
      </div>
    </section>
  </div>

  <style is:global>
    /* Gradient hairline along the top edge of the estimate console */
    .quote-console::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent,
        rgba(18, 216, 204, 0.55),
        transparent
      );
    }

    /* Range slider theming for the quote wizard */
    .quote-slider {
      -webkit-appearance: none;
      appearance: none;
      height: 6px;
      border-radius: 9999px;
      outline: none;
    }
    .quote-slider::-webkit-slider-thumb {
      -webkit-appearance: none;
      appearance: none;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #12d8cc;
      border: 3px solid #fff;
      box-shadow: 0 0 0 4px rgba(18, 216, 204, 0.18), 0 2px 8px rgba(0, 0, 0, 0.3);
      cursor: pointer;
      transition: box-shadow 0.2s ease, transform 0.15s ease;
    }
    .quote-slider::-webkit-slider-thumb:hover {
      box-shadow: 0 0 0 6px rgba(18, 216, 204, 0.24), 0 2px 10px rgba(0, 0, 0, 0.35);
      transform: scale(1.08);
    }
    .quote-slider::-moz-range-thumb {
      width: 22px;
      height: 22px;
      border-radius: 50%;
      background: #12d8cc;
      border: 3px solid #fff;
      box-shadow: 0 0 0 4px rgba(18, 216, 204, 0.18), 0 2px 8px rgba(0, 0, 0, 0.3);
      cursor: pointer;
    }
  </style>
</BaseLayout>
