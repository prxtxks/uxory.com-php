  {
    name: 'NdaRadar',
    desc: 'AI-powered NDA review, drafting, and negotiation tool built for marketing agencies and staffing firms to handle agreements without outside counsel.',
    img: '/images/home-ai/ndaradar.webp',
    link: 'https://ndaradar.com',
  },
  {
    name: 'Credexis',
    desc: 'AI-powered SBA 7(a) underwriting intelligence platform with deterministic financial document extraction and zero-hallucination processing.',
