---
import type { Guide } from '../../data/onboarding';
interface Props { guide: Guide; otherHref: string; otherLabel: string; }
const { guide, otherHref, otherLabel } = Astro.props;
---

<!-- Rendered inside DocsShell: the shell owns the page container and sidebar -
     this component only renders the guide itself. -->
<header class="max-w-3xl">
  <p class="font-satoshi text-sm tracking-[3px] uppercase mb-3 text-primary">
    {guide.flag} Client Onboarding
  </p>
  <h1 class="text-3xl md:text-[40px] font-normal leading-tight">
    Ecommerce Website <span class="font-instrument italic">Onboarding</span>
  </h1>
  <p class="mt-4 text-lg text-secondary/70 dark:text-backgroundBody/70">{guide.subtitle}</p>
  <div class="mt-6 flex flex-wrap gap-3 text-sm">
    <span class="px-3 py-1.5 rounded-full bg-primary/10 text-primary">Region: {guide.country}</span>
    <a href={otherHref} class="px-3 py-1.5 rounded-full border border-secondary/15 dark:border-backgroundBody/15 hover:border-primary/50 transition-colors">
      Viewing {guide.country} → switch to {otherLabel}
    </a>
  </div>
</header>

<div class="mt-10 flex flex-col gap-10 xl:flex-row">
  <!-- "On this page" - right rail on wide screens -->
  <aside class="shrink-0 xl:order-last xl:w-56">
    <nav class="text-sm xl:sticky xl:top-28" aria-label="On this page">
      <p class="uppercase tracking-[2px] text-xs text-secondary/40 dark:text-backgroundBody/40 mb-3">On this page</p>
      <ul class="space-y-1.5">
        {guide.phases.map((p) => (
          <li>
            <a href={`#${p.id}`} class="block py-1 text-secondary/60 dark:text-backgroundBody/60 hover:text-primary transition-colors">
              {p.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </aside>

  <!-- Phases -->
  <div class="min-w-0 flex-1 max-w-3xl">
    <div class="divide-y divide-secondary/[0.08] dark:divide-white/[0.08]">
        {guide.phases.map((phase) => (
          <div id={phase.id} class="scroll-mt-28 py-10 first:pt-0 last:pb-0">
            <h2 class="doc-heading text-2xl md:text-3xl font-normal mb-2">
              {phase.title}
              <a class="doc-anchor" href={`#${phase.id}`} aria-label={`Link to ${phase.title}`}>#</a>
            </h2>
            {phase.intro && <p class="text-secondary/70 dark:text-backgroundBody/70 mb-6">{phase.intro}</p>}

            <div class="space-y-5">
              {phase.blocks.map((block) => {
                if (block.type === 'text') {
                  return <p class="text-secondary/80 dark:text-backgroundBody/80 leading-relaxed">{block.text}</p>;
                }
                if (block.type === 'options') {
                  return (
                    <div class="grid gap-4 sm:grid-cols-1">
                      {block.items.map((it) => (
                        <div class="rounded-2xl border border-secondary/10 dark:border-backgroundBody/10 p-5 bg-secondary/[0.02] dark:bg-backgroundBody/[0.03]">
                          <div class="flex items-center gap-3 mb-1.5">
                            <h3 class="text-lg font-medium">{it.name}</h3>
                            {it.tag && <span class="text-xs px-2 py-0.5 rounded-full bg-primary/15 text-primary">{it.tag}</span>}
                          </div>
                          <p class="text-sm text-secondary/70 dark:text-backgroundBody/70 leading-relaxed">{it.desc}</p>
                        </div>
                      ))}
                    </div>
                  );
                }
                if (block.type === 'accounts') {
                  return (
                    <div class="grid gap-3 sm:grid-cols-2">
                      {block.items.map((it) => (
                        <div class="rounded-xl border border-secondary/10 dark:border-backgroundBody/10 p-4">
                          <p class="font-medium text-primary mb-1">{it.name}</p>
                          <p class="text-sm text-secondary/70 dark:text-backgroundBody/70 leading-relaxed">{it.desc}</p>
                        </div>
                      ))}
                    </div>
                  );
                }
                if (block.type === 'checklist') {
                  return (
                    <ul class="space-y-2.5">
                      {block.items.map((it) => (
                        <li class="flex gap-3">
                          <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 9.7a1 1 0 111.4-1.4l3.8 3.8 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd" />
                          </svg>
                          <span class="text-secondary/80 dark:text-backgroundBody/80">{it}</span>
                        </li>
                      ))}
                    </ul>
                  );
                }
                if (block.type === 'note') {
                  const isWarn = block.variant === 'warn';
                  return (
                    <div class={`rounded-xl p-4 border-l-4 ${isWarn ? 'border-amber-400 bg-amber-400/10' : 'border-primary bg-primary/10'}`}>
                      <p class="text-sm text-secondary/80 dark:text-backgroundBody/80 leading-relaxed">
                        <span class="font-medium">{isWarn ? '⚠ Important - ' : 'ℹ Note - '}</span>{block.text}
                      </p>
                    </div>
                  );
                }
                if (block.type === 'table') {
                  return (
                    <div class="overflow-x-auto rounded-xl border border-secondary/10 dark:border-backgroundBody/10">
                      <table class="w-full text-sm">
                        <thead>
                          <tr class="bg-secondary/[0.04] dark:bg-backgroundBody/[0.05]">
                            {block.headers.map((h) => <th class="text-left font-medium px-4 py-3">{h}</th>)}
                          </tr>
                        </thead>
                        <tbody>
                          {block.rows.map((row) => (
                            <tr class="border-t border-secondary/10 dark:border-backgroundBody/10">
                              {row.map((cell) => <td class="px-4 py-3 text-secondary/75 dark:text-backgroundBody/75 align-top">{cell}</td>)}
                            </tr>
                          ))}
                        </tbody>
                      </table>
                    </div>
                  );
                }
                return null;
              })}
            </div>
          </div>
        ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 rounded-2xl border border-primary/30 bg-primary/5 p-8 text-center">
      <h3 class="text-2xl font-normal mb-2">Ready to start?</h3>
      <p class="text-secondary/70 dark:text-backgroundBody/70 mb-5">
        Book a call and we'll walk you through this for your specific store - no obligation.
      </p>
      <a href="/contact" class="inline-block bg-primary text-black font-medium px-6 py-3 rounded-2xl hover:opacity-90 transition-opacity">
        Talk to Uxory
      </a>
    </div>
  </div>
</div>
