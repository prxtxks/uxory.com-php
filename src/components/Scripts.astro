---
// Scripts component - converted from components/scripts.php
interface Props { recaptcha?: boolean; }
// Default true so every page that renders a form (the newsletter subscribe form
// lives in the sitewide Blog component) keeps working; form-less pages opt out.
const { recaptcha = true } = Astro.props;
---

<!--=====================================
   Scripts
======================================-->

<script is:inline src="/js/lib/imagesloaded.pkgd.min.js"></script>
<script is:inline src="/js/lib/gsap.min.js"></script>
<script is:inline src="/js/lib/ScrollTrigger.min.js"></script>
<script is:inline src="/js/lib/lenis.min.js"></script>
<script is:inline src="/js/lib/split-types.min.js"></script>
<script is:inline src="/js/lib/matter.min.js"></script>
<script is:inline src="/js/lib/swiper.min.js"></script>
<script is:inline src="/js/lib/headroom.min.js"></script>
<script is:inline src="/js/lib/vanila-marquee.min.js"></script>
<script is:inline src="/js/career-tabs.js"></script>
<script is:inline src="/js/script.js"></script>
<script is:inline src="/js/subscribe.js"></script>
<script is:inline src="/js/unsubscribe.js"></script>

<script is:inline src="/js/contact.js"></script>
<script is:inline src="/js/application.js"></script>

<!-- Google Captcha (explicit render – widgets shown only when needed).
     Loaded only on pages that render a protected form. -->
{recaptcha && <script is:inline src="https://www.google.com/recaptcha/api.js?render=explicit" async defer></script>}
