---
// Reusable FAQ accordion + matching FAQPage structured data.
// Both the visible Q&A and the JSON-LD are generated from the same `items`
// array, so the schema always matches what the user sees (a Google requirement).
//
// The accordion markup mirrors faq.astro so the global accordion JS
// (public/js/script.js) drives it with no extra wiring.

export interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
  heading?: string;
  /** Absolute URL of the page this FAQ lives on, used as the schema @id base. */
  pageUrl?: string;
}

const { items, heading = 'Frequently Asked Questions', pageUrl } = Astro.props;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  ...(pageUrl ? { '@id': `${pageUrl}#faq` } : {}),
  mainEntity: items.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: it.a,
    },
  })),
};
---

<!--=====================================
   FAQ Section (service page)
======================================-->
<section
  class="pt-14 md:pt-16 lg:pt-[88px] xl:pt-[100px] pb-14 md:pb-16 lg:pb-[88px] xl:pb-[100px] relative"
>
  <div class="container">
    <p
      class="font-satoshi text-center text-sm font-normal leading-6 tracking-[3px] uppercase reveal-me @@badge"
    >
      FAQ
    </p>
    <h2 class="mt-3 mb-10 md:mb-16 text-center text-appear-2">
      {heading}
    </h2>

    <div
      class="max-w-[900px] w-full mx-auto [&>*:not(:last-child)]:mb-6 reveal-me"
    >
      {
        items.map((it) => (
          <div
            class="accordion-item overflow-hidden bg-backgroundBody dark:bg-dark border border-backgroundBody dark:border-[#151515] duration-300"
          >
            <div
              class="accordion-header relative cursor-pointer py-5 md:py-[35px] max-md:px-5 md:px-10"
            >
              <h3
                class="text-xl md:text-[25px] font-normal sm:font-medium md:leading-[25.2px] md:tracking-normal max-md:inline-block max-lg:pr-10"
              >
                {it.q}
              </h3>
              <div class="accordion-header-icon dark:border-dark" />
            </div>
            <p
              class="accordion-body max-md:text-sm max-md:px-5 md:px-10 duration-300 h-0"
            >
              {it.a}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
