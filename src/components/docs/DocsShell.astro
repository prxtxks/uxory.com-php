---
/**
 * Docs portal chrome: categorized left sidebar (with quick filter), breadcrumb,
 * content area, and prev/next footer navigation - the Gemini/AWS docs pattern
 * in Uxory's own theme. Wrap any docs page content in this shell and pass the
 * page's registry `current` href so the sidebar highlights and prev/next work.
 */
import { DOCS_NAV, findDoc } from '../../data/docsNav';

interface Props {
  /** The current page's href as registered in docsNav.ts, e.g. "/docs/legal-pages-india". */
  current: string;
}

const { current } = Astro.props;
const { doc, prev, next } = findDoc(current);
---

<div class="pt-[96px] md:pt-[120px] pb-16 md:pb-24">
  <div class="container px-5 md:px-8">
    <div class="flex flex-col lg:flex-row lg:gap-10 xl:gap-14">
      <!-- ── Sidebar ── -->
      <aside class="lg:w-[264px] shrink-0">
        <!-- Mobile: collapsible; desktop: always visible & sticky -->
        <details class="docs-sidebar group lg:[&>summary]:hidden" id="docs-sidebar">
          <summary
            class="flex cursor-pointer list-none items-center justify-between rounded-xl border border-secondary/10 px-4 py-3 text-[15px] font-medium text-secondary dark:border-white/10 dark:text-backgroundBody [&::-webkit-details-marker]:hidden"
          >
            Documentation menu
            <svg class="h-4 w-4 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>

          <nav class="mt-4 lg:mt-0 lg:sticky lg:top-28 lg:max-h-[calc(100vh-140px)] lg:overflow-y-auto lg:pr-3 docs-scroll" aria-label="Documentation">
            <a href="/docs" class="mb-5 hidden items-center gap-2 text-[13px] font-medium uppercase tracking-[2.5px] text-secondary/45 transition-colors hover:text-primary dark:text-backgroundBody/45 lg:flex">
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h10"/></svg>
              Docs home
            </a>

            <!-- Quick filter -->
            <div class="relative mb-6">
              <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-secondary/35 dark:text-backgroundBody/35" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="7" /><path stroke-linecap="round" d="M20 20l-3.5-3.5" />
              </svg>
              <input
                id="docs-filter"
                type="text"
                placeholder="Filter docs..."
                autocomplete="off"
                class="w-full rounded-lg border border-secondary/10 bg-white/60 py-2 pl-9 pr-3 text-sm text-secondary outline-none transition-colors placeholder:text-secondary/35 focus:border-primary dark:border-white/10 dark:bg-white/[0.04] dark:text-backgroundBody dark:placeholder:text-backgroundBody/30"
              />
            </div>

            <div class="space-y-7">
              {DOCS_NAV.map((cat) => (
                <div class="docs-cat">
                  <p class="mb-2.5 text-[11px] font-semibold uppercase tracking-[2px] text-secondary/40 dark:text-backgroundBody/40">
                    {cat.title}
                  </p>
                  <ul class="space-y-0.5 border-l border-secondary/10 dark:border-white/10">
                    {cat.items.map((item) => {
                      const active = item.href === current;
                      return (
                        <li class="docs-link" data-title={`${item.title} ${cat.title}`.toLowerCase()}>
                          <a
                            href={item.href}
                            aria-current={active ? 'page' : undefined}
                            class={`-ml-px flex items-center gap-2 border-l-2 py-1.5 pl-4 pr-2 text-[14.5px] leading-snug transition-colors ${
                              active
                                ? 'border-primary font-medium text-primary'
                                : 'border-transparent text-secondary/65 hover:border-secondary/30 hover:text-secondary dark:text-backgroundBody/65 dark:hover:border-white/30 dark:hover:text-backgroundBody'
                            }`}
                          >
                            <span>{item.title}</span>
                            {item.badge && (
                              <span class="rounded-full bg-primary/10 px-1.5 py-px text-[10px] font-semibold uppercase tracking-wide text-primary">
                                {item.badge}
                              </span>
                            )}
                          </a>
                        </li>
                      );
                    })}
                  </ul>
                </div>
              ))}
              <p id="docs-filter-empty" class="hidden text-sm text-secondary/45 dark:text-backgroundBody/45">
                No docs match your filter.
              </p>
            </div>
          </nav>
        </details>
      </aside>

      <!-- ── Content ── -->
      <div class="mt-8 min-w-0 flex-1 lg:mt-0">
        {doc && (
          <nav class="mb-2 flex flex-wrap items-center gap-1.5 text-[13px] text-secondary/45 dark:text-backgroundBody/45" aria-label="Breadcrumb">
            <a href="/docs" class="transition-colors hover:text-primary">Docs</a>
            <span aria-hidden="true">/</span>
            <span>{doc.category}</span>
            <span aria-hidden="true">/</span>
            <span class="text-secondary/70 dark:text-backgroundBody/70">{doc.title}</span>
          </nav>
        )}

        <slot />

        <!-- Prev / next -->
        {(prev || next) && (
          <div class="mt-14 grid gap-4 border-t border-secondary/10 pt-8 dark:border-white/10 sm:grid-cols-2">
            {prev ? (
              <a href={prev.href} class="group rounded-2xl border border-secondary/10 p-5 transition-colors hover:border-primary/50 dark:border-white/10">
                <p class="mb-1 text-xs uppercase tracking-[2px] text-secondary/40 dark:text-backgroundBody/40">← Previous</p>
                <p class="font-medium text-secondary transition-colors group-hover:text-primary dark:text-backgroundBody">{prev.title}</p>
              </a>
            ) : (
              <span class="hidden sm:block" />
            )}
            {next && (
              <a href={next.href} class="group rounded-2xl border border-secondary/10 p-5 text-right transition-colors hover:border-primary/50 dark:border-white/10">
                <p class="mb-1 text-xs uppercase tracking-[2px] text-secondary/40 dark:text-backgroundBody/40">Next →</p>
                <p class="font-medium text-secondary transition-colors group-hover:text-primary dark:text-backgroundBody">{next.title}</p>
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
  .docs-scroll {
    scrollbar-width: thin;
  }
</style>

<style is:global>
  /* ── Docs reading experience (applies inside the shell) ── */

  /* Scrollspy: the TOC link whose section is in view */
  nav[aria-label='On this page'] a.toc-active {
    color: #12d8cc;
    font-weight: 500;
  }
  nav[aria-label='On this page'] ul {
    border-left: 1px solid rgba(24, 24, 24, 0.1);
  }
  .dark nav[aria-label='On this page'] ul {
    border-left-color: rgba(255, 255, 255, 0.1);
  }
  nav[aria-label='On this page'] ul a {
    padding-left: 14px;
    margin-left: -1px;
    border-left: 2px solid transparent;
  }
  nav[aria-label='On this page'] ul a.toc-active {
    border-left-color: #12d8cc;
  }

  /* Hover anchor links on section headings */
  .doc-heading {
    position: relative;
  }
  .doc-heading .doc-anchor {
    margin-left: 10px;
    font-weight: 400;
    color: rgba(18, 216, 204, 0.85);
    opacity: 0;
    text-decoration: none;
    transition: opacity 0.15s ease;
  }
  .doc-heading:hover .doc-anchor,
  .doc-anchor:focus-visible {
    opacity: 1;
  }
</style>

<script is:inline>
  // Scrollspy for the per-page "On this page" rail. Generic: works for any
  // content layout inside the shell whose TOC is nav[aria-label="On this page"]
  // with #hash links pointing at elements with matching ids.
  (function () {
    const nav = document.querySelector('nav[aria-label="On this page"]');
    if (!nav) return;
    const links = Array.from(nav.querySelectorAll('a[href^="#"]'));
    const byId = new Map();
    const targets = [];
    links.forEach((a) => {
      const id = decodeURIComponent(a.getAttribute('href').slice(1));
      const el = document.getElementById(id);
      if (el) {
        byId.set(id, a);
        targets.push(el);
      }
    });
    if (!targets.length) return;

    let activeId = null;
    const setActive = (id) => {
      if (id === activeId) return;
      activeId = id;
      links.forEach((a) => a.classList.remove('toc-active'));
      const link = byId.get(id);
      if (link) link.classList.add('toc-active');
    };

    // Pick the last section whose top has passed the reading line (~35% vh).
    const onScroll = () => {
      const vh = window.innerHeight || document.documentElement.clientHeight || 800;
      const line = vh * 0.35;
      let current = targets[0].id;
      for (const el of targets) {
        if (el.getBoundingClientRect().top <= line) current = el.id;
        else break;
      }
      setActive(current);
    };
    // Timeout throttle (not rAF - rAF is suspended in background/throttled
    // tabs and the spy would freeze).
    let pending = false;
    window.addEventListener(
      'scroll',
      () => {
        if (pending) return;
        pending = true;
        setTimeout(() => {
          pending = false;
          onScroll();
        }, 80);
      },
      { passive: true }
    );
    onScroll();
  })();
</script>

<script is:inline>
  // Desktop: keep the sidebar <details> open (summary is hidden by CSS there).
  (function () {
    const sidebar = document.getElementById('docs-sidebar');
    if (!sidebar) return;
    const sync = () => {
      if (window.innerWidth >= 1024) sidebar.open = true;
    };
    sync();
    window.addEventListener('resize', sync);
  })();

  // Sidebar quick filter: hides non-matching links and empty categories.
  (function () {
    const input = document.getElementById('docs-filter');
    if (!input) return;
    const links = Array.from(document.querySelectorAll('.docs-link'));
    const cats = Array.from(document.querySelectorAll('.docs-cat'));
    const empty = document.getElementById('docs-filter-empty');
    input.addEventListener('input', function () {
      const q = this.value.trim().toLowerCase();
      let shown = 0;
      links.forEach((li) => {
        const hit = !q || (li.getAttribute('data-title') || '').includes(q);
        li.style.display = hit ? '' : 'none';
        if (hit) shown++;
      });
      cats.forEach((cat) => {
        const any = Array.from(cat.querySelectorAll('.docs-link')).some((li) => li.style.display !== 'none');
        cat.style.display = any ? '' : 'none';
      });
      if (empty) empty.classList.toggle('hidden', shown > 0);
    });
  })();
</script>
