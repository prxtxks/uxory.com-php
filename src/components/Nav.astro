          </li>
        </ul>
      </li>

      <li class={`menu-list-item menu-list-item-anchor ${currentParent === 'docs' ? 'active' : ''}`}>
        <a
          href="#"
          class="text-white text-[26px] md:text-[40px] xl:text-[56px] leading-[46px] md:leading-[64px] xl:leading-[90px] menu-list-item-text"
          >Docs</a
        >
        <ul
          class="menu-list-item-dropdown relative md:absolute top-0 w-full md:w-auto h-fit left-0 md:left-[48%]"
        >
          <li>
            <a
              href="/onboarding/ecommerce-india"
              class={`text-white inline-block pb-1 pl-3 menu-list-item-dropdown-list text-base md:text-lg leading-8 md:leading-[50px] ${currentPage === 'onboarding-india' ? 'active' : ''}`}
              >Ecommerce Onboarding — India
            </a>
          </li>
          <li>
            <a
