            </a>
          </li>

        </ul>
      </li>

      <li class={`menu-list-item menu-list-item-anchor ${currentParent === 'about' ? 'active' : ''}`}>
        <a
          href="#"
          class="text-white text-[26px] md:text-[40px] xl:text-[56px] leading-[46px] md:leading-[64px] xl:leading-[90px] menu-list-item-text"
          >About</a
        >
        <ul
          class="menu-list-item-dropdown relative md:absolute top-0 w-full md:w-auto h-fit left-0 md:left-[48%]"
        >

          <li>
            <a
              href="/about-us"
              class={`text-white inline-block pb-1 pl-3 menu-list-item-dropdown-list text-base md:text-lg leading-8 md:leading-[50px] ${currentPage === 'about-us' ? 'active' : ''}`}
              >About Us</a
            >
          </li>

          <li>
            <a
              href="/reviews"
              class={`text-white inline-block pb-1 pl-3 menu-list-item-dropdown-list text-base md:text-lg leading-8 md:leading-[50px] ${currentPage === 'reviews' ? 'active' : ''}`}
              >Client Reviews
            </a>
          </li>

          <li>
            <a
              href="/refer"
              class={`text-white inline-block pb-1 pl-3 menu-list-item-dropdown-list text-base md:text-lg leading-8 md:leading-[50px] ${currentPage === 'refer' ? 'active' : ''}`}
              >Refer Us
            </a>
          </li>

          <li>
            <a
              href="/blog-listings"
              class={`text-white inline-block pb-1 pl-3 menu-list-item-dropdown-list text-base md:text-lg leading-8 md:leading-[50px] ${currentPage === 'blog' ? 'active' : ''}`}
              >Blogs & Insights
            </a>
          </li>
          
          <li>
            <a
              href="/faq"
